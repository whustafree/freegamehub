# ============================================
# GameRadar - Environment Variables
# ============================================
# Copy this file to .env and set your values:
# cp .env.example .env

# --- Push Notifications (VAPID) ---
# Generate: npx web-push generate-vapid-keys
# Or let auto-generate on first run (saved to data/vapid-keys.json)
# For production, set these env vars:
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@gameradar.app

# --- Telegram (opcional) ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- Instagram (opcional) ---
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# --- Server ---
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
UPDATE_INTERVAL_HOURS=4
