# ============================================
# FreeGameHub v2.0 - Variables de Entorno
# Copia este archivo como .env y completa los valores
# ============================================

# --- Telegram (opcional pero recomendado) ---
# 1. Habla con @BotFather en Telegram, crea un bot con /newbot
# 2. Obtén tu chat ID: node get_id.js (escribe "Hola" a tu bot primero)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- Reddit (opcional - para ofertas de Android r/googleplaydeals) ---
# 1. Ve a https://www.reddit.com/prefs/apps
# 2. Crea una app tipo "script"
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- App ---
# URL pública (para enlaces en notificaciones de Telegram)
APP_URL=http://localhost:3000
# Intervalo de actualización automática en horas
UPDATE_INTERVAL_HOURS=4
